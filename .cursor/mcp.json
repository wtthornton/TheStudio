{
  "mcpServers": {
    "MCP_DOCKER": {
      "command": "docker",
      "args": [
        "mcp",
        "gateway",
        "run"
      ],
      "env": {
        "LOCALAPPDATA": "C:\\Users\\tappt\\AppData\\Local",
        "ProgramData": "C:\\ProgramData",
        "ProgramFiles": "C:\\Program Files"
      }
    },
    "tapps-mcp": {
      "type": "stdio",
      "command": "tapps-mcp",
      "args": [
        "serve"
      ],
      "env": {
        "TAPPS_MCP_PROJECT_ROOT": "${workspaceFolder}"
      }
    }
  }
}
