# .ralphrc - Ralph project configuration
# Documentation: https://github.com/frankbria/ralph-claude-code

# =============================================================================
# PROJECT IDENTIFICATION
# =============================================================================

PROJECT_NAME="TheStudio"
PROJECT_TYPE="python"

# =============================================================================
# LOOP SETTINGS
# =============================================================================

MAX_CALLS_PER_HOUR=100
CLAUDE_TIMEOUT_MINUTES=30
CLAUDE_OUTPUT_FORMAT="json"

# =============================================================================
# TOOL PERMISSIONS
# =============================================================================

# Granular Bash permissions — prevents destructive git commands (git clean, git rm, git reset)
# Note: git -C is needed when Claude runs git from a subdirectory (e.g., cd frontend && git -C /repo add ...)
# Note: mcp__* patterns grant access to MCP server tools (tapps-mcp, docs-mcp)
ALLOWED_TOOLS="Write,Read,Edit,Glob,Grep,TodoWrite,WebFetch,mcp__tapps-mcp__*,mcp__docs-mcp__*,Bash(git add *),Bash(git -C *),Bash(git commit *),Bash(git diff *),Bash(git log *),Bash(git status),Bash(git status *),Bash(git push *),Bash(git pull *),Bash(git fetch *),Bash(git checkout *),Bash(git branch *),Bash(git stash *),Bash(git merge *),Bash(git tag *),Bash(pip *),Bash(python *),Bash(python3 *),Bash(pytest *),Bash(pytest),Bash(ruff *),Bash(mypy *),Bash(npm *),Bash(npx *),Bash(node *),Bash(ls *),Bash(cat *),Bash(mkdir *),Bash(cp *),Bash(mv *),Bash(head *),Bash(tail *),Bash(wc *),Bash(find *),Bash(which *),Bash(echo *),Bash(grep *),Bash(cd *),Bash(xargs *),Bash(sort *),Bash(tee *),Bash(rm *)"

# =============================================================================
# SESSION MANAGEMENT
# =============================================================================

SESSION_CONTINUITY=false
SESSION_EXPIRY_HOURS=24

# =============================================================================
# TASK SOURCES
# =============================================================================

TASK_SOURCES="github,local"
GITHUB_TASK_LABEL="ralph-task"
BEADS_FILTER="status:open"

# =============================================================================
# CIRCUIT BREAKER THRESHOLDS
# =============================================================================

# Trip after 3 loops with no file changes (was 10 — too permissive)
CB_NO_PROGRESS_THRESHOLD=3

# Trip after 5 loops with the same error
CB_SAME_ERROR_THRESHOLD=3

# Trip if output declines by more than 70%
CB_OUTPUT_DECLINE_THRESHOLD=70

# Cooldown before retry (minutes)
CB_COOLDOWN_MINUTES=10

# Do NOT auto-reset — let the cooldown work
CB_AUTO_RESET=false

# =============================================================================
# ADVANCED SETTINGS
# =============================================================================

CLAUDE_AUTO_UPDATE=false
CLAUDE_MIN_VERSION="2.0.76"
RALPH_VERBOSE=false

# Agent mode (v1.0+): use --agent ralph instead of -p with --allowedTools
# When true, uses .claude/agents/ralph.md agent definition (requires CLI v2.1+)
# Falls back to legacy -p mode if CLI does not support --agent
RALPH_USE_AGENT=true
RALPH_AGENT_NAME="ralph"

# =============================================================================
# LOG ROTATION
# =============================================================================

# Maximum ralph.log file size before rotation (in MB)
LOG_MAX_SIZE_MB=10

# Number of rotated log files to keep (ralph.log.1, ralph.log.2, ...)
LOG_MAX_FILES=5

# Maximum claude_output_*.log files to keep (oldest deleted first)
LOG_MAX_OUTPUT_FILES=20

# =============================================================================
# DRY-RUN MODE
# =============================================================================

# Preview loop execution without making API calls
# Also activatable via: ralph --dry-run
DRY_RUN=false

# =============================================================================
# PARALLELISM (v1.1.0 Phase 4 — Experimental)
# =============================================================================

# Enable agent teams for parallel execution
# WARNING: Experimental feature. Requires Claude Code v2.1.32+
RALPH_ENABLE_TEAMS=false
RALPH_MAX_TEAMMATES=3

# Background testing (independent of teams)
RALPH_BG_TESTING=false

# Teammate display mode: "in-process" | "tmux" | "auto"
RALPH_TEAMMATE_MODE="tmux"
