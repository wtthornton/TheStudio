# TheStudio Production Test Rig — copy to .env and set for your deployment.
# Contract: docs/production-test-rig-contract.md in TheStudio repo.
# Poll E2E tests only — no webhook tests.

# Base URL of the deployed TheStudio (no trailing slash).
THESTUDIO_BASE_URL=https://localhost:9443

# Set to 1 to skip TLS verification (e.g. self-signed cert).
THESTUDIO_INSECURE_TLS=1

# X-User-ID for admin API (default dev-admin@localhost).
THESTUDIO_ADMIN_USER=dev-admin@localhost

# For poll E2E: owner/repo to register and poll (e.g. wtthornton/TheStudio).
# THESTUDIO_POLL_TEST_REPO=wtthornton/TheStudio
