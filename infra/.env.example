# TheStudio Production Environment Variables
# Copy to .env and fill in real values before deploying.

# REQUIRED: Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
THESTUDIO_ENCRYPTION_KEY=

# LLM Provider: "mock" (default) or "anthropic"
THESTUDIO_LLM_PROVIDER=mock
THESTUDIO_ANTHROPIC_API_KEY=

# GitHub Integration: "mock" (default) or "real"
THESTUDIO_GITHUB_PROVIDER=mock
THESTUDIO_GITHUB_APP_ID=
THESTUDIO_GITHUB_PRIVATE_KEY_PATH=

# Observability: "console" (default) or "otlp"
THESTUDIO_OTEL_EXPORTER=console
