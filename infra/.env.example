# TheStudio Environment Variables
# Copy to .env and fill in real values before deploying.
# For production: use docker-compose.prod.yml

# REQUIRED: Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
THESTUDIO_ENCRYPTION_KEY=

# REQUIRED for production: Set a strong PostgreSQL password
POSTGRES_PASSWORD=thestudio_dev

# LLM Provider: "mock" (default/dev) or "anthropic" (production)
THESTUDIO_LLM_PROVIDER=mock
THESTUDIO_ANTHROPIC_API_KEY=

# GitHub Integration: "mock" (default/dev) or "real" (production)
THESTUDIO_GITHUB_PROVIDER=mock
THESTUDIO_GITHUB_APP_ID=
THESTUDIO_GITHUB_PRIVATE_KEY_PATH=

# Webhook secret for GitHub webhook signature validation
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
THESTUDIO_WEBHOOK_SECRET=

# Observability: "console" (default) or "otlp" (production)
THESTUDIO_OTEL_EXPORTER=console
