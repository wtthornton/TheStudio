# TheStudio Production — Environment Variables
# Copy to .env and fill in all required values before running:
#   docker compose -f docker-compose.prod.yml up -d

# --- Required ---
POSTGRES_PASSWORD=              # Strong random password for PostgreSQL
THESTUDIO_ENCRYPTION_KEY=       # Base64 Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
THESTUDIO_ANTHROPIC_API_KEY=    # Anthropic API key (sk-ant-...)

# Caddy admin auth — generate hash with:
#   docker run --rm caddy:2.9-alpine caddy hash-password --plaintext 'YOUR_PASSWORD'
ADMIN_USER=admin
ADMIN_PASSWORD_HASH=

# --- GitHub App ---
THESTUDIO_GITHUB_APP_ID=
THESTUDIO_GITHUB_PRIVATE_KEY_PATH=/app/infra/github-app.pem
THESTUDIO_WEBHOOK_SECRET=

# --- Optional: Anthropic OAuth (default: api-key mode) ---
# THESTUDIO_ANTHROPIC_AUTH_MODE=auto
# THESTUDIO_ANTHROPIC_REFRESH_TOKEN=
# THESTUDIO_ANTHROPIC_OAUTH_CLIENT_ID=9d1c250a-e61b-44d9-88ed-5944d1962f5e

# --- Optional: Providers ---
# THESTUDIO_LLM_PROVIDER=anthropic          # anthropic | mock
# THESTUDIO_GITHUB_PROVIDER=real            # real | mock

# --- Optional: Intake Polling ---
# THESTUDIO_INTAKE_POLL_ENABLED=false
# THESTUDIO_INTAKE_POLL_INTERVAL_MINUTES=10
# THESTUDIO_INTAKE_POLL_TOKEN=

# --- Optional: Observability ---
# THESTUDIO_OTEL_EXPORTER=console           # console | otlp

# --- Optional: Caddy / TLS ---
# THESTUDIO_HTTPS_ENABLED=false             # false = HTTP only (port 9080), true = HTTPS (port 9443)

# --- Optional: Feature Flags ---
# THESTUDIO_APPROVAL_AUTO_BYPASS=false      # NEVER true in production
# THESTUDIO_PREFLIGHT_ENABLED=false
# THESTUDIO_PREFLIGHT_TIERS=["execute"]
# THESTUDIO_AGENT_ISOLATION=process
# THESTUDIO_COST_OPTIMIZATION_ROUTING_ENABLED=false
# THESTUDIO_COST_OPTIMIZATION_CACHING_ENABLED=false

# --- Optional: Projects v2 Integration (Epic 29) ---
# THESTUDIO_PROJECTS_V2_ENABLED=false
# THESTUDIO_PROJECTS_V2_OWNER=
# THESTUDIO_PROJECTS_V2_NUMBER=0
# THESTUDIO_PROJECTS_V2_TOKEN=

# --- Optional: Meridian Portfolio (Epic 29) ---
# THESTUDIO_MERIDIAN_PORTFOLIO_ENABLED=false
# THESTUDIO_MERIDIAN_PORTFOLIO_GITHUB_ISSUE=false
# THESTUDIO_MERIDIAN_PORTFOLIO_REPO=
