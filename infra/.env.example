# TheStudio Production Environment Variables
# Copy to .env and fill in real values before deploying.
# Run infra/check-env.sh to validate before starting the stack.
#
# For production: docker compose -f docker-compose.prod.yml up -d

# ─── REQUIRED ────────────────────────────────────────────────────────────────

# PostgreSQL password (min 12 characters)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=

# Fernet encryption key for at-rest encryption
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
THESTUDIO_ENCRYPTION_KEY=

# Anthropic API key for LLM calls
THESTUDIO_ANTHROPIC_API_KEY=

# ─── RECOMMENDED ─────────────────────────────────────────────────────────────

# GitHub webhook signature validation secret
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
THESTUDIO_WEBHOOK_SECRET=

# GitHub App credentials (required for real GitHub integration)
THESTUDIO_GITHUB_APP_ID=
THESTUDIO_GITHUB_PRIVATE_KEY_PATH=

# ─── OPTIONAL (defaults shown) ──────────────────────────────────────────────

# LLM Provider: "anthropic" (production) or "mock" (testing)
# THESTUDIO_LLM_PROVIDER=anthropic

# GitHub Provider: "real" (production) or "mock" (testing)
# THESTUDIO_GITHUB_PROVIDER=real

# Observability: "console" (default) or "otlp" (production with collector)
# THESTUDIO_OTEL_EXPORTER=console
